---
import { Image } from 'astro:assets';
import heroCutout from '../assets/img/hero-cutout.png';
---

<section id="top" class="relative flex min-h-[100svh] snap-start flex-col overflow-hidden">
  <!-- Фон-сцена: мягкий бело-розовый luxury -->
  <div aria-hidden="true" class="absolute inset-0 -z-20 bg-gradient-to-b from-pink-soft via-white to-white"></div>
  <!-- Сценическое розовое свечение под фигурой -->
  <div
    aria-hidden="true"
    class="anim-blob pointer-events-none absolute bottom-[-8%] right-[-12%] -z-10 h-[55svh] w-[85vw] rounded-full bg-pink/25 blur-3xl"
  >
  </div>

  <!-- Фигура Кати: вне потока — не толкает контент и не режется за фолдом -->
  <div
    id="heroFigure"
    class="reveal pointer-events-none absolute bottom-0 right-[-10vw] z-0 sm:right-[-4vw] lg:right-[2vw]"
    style="--reveal-delay:0"
  >
    <div class="hero-parallax">
      <Image
        src={heroCutout}
        alt="Катя Усманова — чемпионка фитнес-бикини и тренер"
        widths={[280, 420, 560]}
        sizes="(min-width: 1024px) 460px, 75vw"
        class="anim-float h-[clamp(340px,60svh,580px)] w-auto object-contain drop-shadow-[0_30px_45px_rgba(246,98,151,0.22)]"
        loading="eager"
        fetchpriority="high"
      />
    </div>
  </div>

  <!-- Лёгкий scrim для читаемости текста поверх фигуры -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 z-[1] bg-gradient-to-b from-white/85 via-white/25 to-transparent lg:bg-gradient-to-r lg:from-white/90 lg:via-white/40 lg:to-transparent"
  >
  </div>

  <!-- Контент -->
  <div
    class="relative z-10 mx-auto flex w-full max-w-6xl flex-1 flex-col px-4 pb-28 pt-20 text-left sm:px-6 sm:pt-24 lg:pt-28"
  >
    <div class="max-w-[20rem] sm:max-w-md lg:max-w-[35rem]">
      <span
        class="reveal inline-flex items-center gap-2 rounded-full border border-pink/25 bg-white/70 px-4 py-1.5 text-xs font-semibold text-pink backdrop-blur-sm sm:text-sm"
      >
        <span aria-hidden="true">★</span> Фитнес с Катей Усмановой
      </span>

      <h1
        class="reveal mt-4 text-[1.9rem] font-extrabold leading-[1.07] tracking-tight sm:mt-5 sm:text-5xl lg:text-[3.4rem]"
        style="--reveal-delay:80"
      >
        Приведите тело в форму с{' '}
        <span class="relative inline-block whitespace-nowrap text-pink">
          чемпионкой
          <span aria-hidden="true" class="hero-underline absolute -bottom-1 left-0 h-[4px] w-full rounded-full bg-pink/45"></span>
        </span>{' '}
        Катей Усмановой
      </h1>

      <p class="reveal mt-4 max-w-sm text-base font-medium text-ink/85 sm:text-lg" style="--reveal-delay:150">
        Без диет, голода и запретов — с пользой для здоровья.
      </p>

      <div class="reveal mt-6 flex flex-col items-start gap-3 sm:flex-row sm:items-center" style="--reveal-delay:230">
        <a
          href="#form"
          class="btn-shine inline-flex items-center justify-center rounded-full bg-pink px-7 py-4 text-base font-semibold text-white shadow-lg shadow-pink/30 transition-transform duration-200 hover:-translate-y-0.5 hover:bg-pink-hot"
        >
          Выбрать программу
        </a>
        <a
          href="#programs"
          class="glass hidden items-center justify-center rounded-full px-7 py-4 text-base font-semibold text-ink transition-colors hover:text-pink sm:inline-flex"
        >
          Смотреть программы
        </a>
      </div>
    </div>

    <!-- Счётчики как стеклянные пилюли -->
    <div class="reveal mt-auto flex flex-wrap gap-2 pt-10" style="--reveal-delay:340">
      <div
        class="glass inline-flex items-baseline gap-1.5 rounded-full px-3.5 py-2"
      >
        <span class="font-extrabold text-pink"><span data-count="580000" data-suffix="+">0</span></span>
        <span class="text-xs text-muted">учениц</span>
      </div>
      <div
        class="glass inline-flex items-baseline gap-1.5 rounded-full px-3.5 py-2"
      >
        <span class="font-extrabold text-pink"><span data-count="15">0</span></span>
        <span class="text-xs text-muted">лет опыта</span>
      </div>
      <div
        class="glass inline-flex items-baseline gap-1.5 rounded-full px-3.5 py-2"
      >
        <span class="font-extrabold text-pink"><span id="liveCount" data-count="3696">0</span></span>
        <span class="text-xs text-muted">сейчас тренируются</span>
      </div>
    </div>
  </div>
</section>

<script>
  // Лёгкий pointer-parallax для фигуры (desktop + fine pointer, уважает reduced-motion)
  const fig = document.getElementById('heroFigure');
  const section = document.getElementById('top');
  const fine = window.matchMedia('(hover: hover) and (pointer: fine)').matches;
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const target = fig?.querySelector<HTMLElement>('.hero-parallax');

  if (target && section && fine && !reduce) {
    let raf = 0;
    section.addEventListener('pointermove', (e) => {
      const r = section.getBoundingClientRect();
      const dx = (e.clientX - r.left) / r.width - 0.5;
      const dy = (e.clientY - r.top) / r.height - 0.5;
      if (raf) cancelAnimationFrame(raf);
      raf = requestAnimationFrame(() => {
        target.style.transform = `translate3d(${dx * 22}px, ${dy * 14}px, 0)`;
      });
    });
    section.addEventListener('pointerleave', () => {
      if (raf) cancelAnimationFrame(raf);
      target.style.transform = '';
    });
  }
</script>
