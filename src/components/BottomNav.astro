---
// Плавающий стеклянный таб-бар (app-style). Активный экран подсвечивается по скроллу.
// Отступ снизу учитывает safe-area iPhone (home-indicator).
---

<nav
  id="appnav"
  aria-label="Навигация по разделам"
  class="glass-liquid fixed left-1/2 z-50 -translate-x-1/2 rounded-full p-1.5"
  style="bottom: calc(1rem + env(safe-area-inset-bottom))"
>
  <ul class="flex items-center gap-1">
    <li>
      <a href="#top" data-nav="top" class="appnav-item is-active" aria-label="Главная">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M3 10.5 12 3l9 7.5" />
          <path d="M5 9.5V21h5v-6h4v6h5V9.5" />
        </svg>
        <span>Главная</span>
      </a>
    </li>
    <li>
      <a href="#programs" data-nav="programs" class="appnav-item" aria-label="Программы">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M6.5 7v10M17.5 7v10M3.5 9.5v5M20.5 9.5v5M6.5 12h11" />
        </svg>
        <span>Программы</span>
      </a>
    </li>
    <li>
      <a href="#form" data-nav="form" class="appnav-item" aria-label="Заявка">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 11.5a7.5 7.5 0 0 1-10.9 6.7L4 20l1.8-4.9A7.5 7.5 0 1 1 21 11.5z" />
        </svg>
        <span>Заявка</span>
      </a>
    </li>
  </ul>
</nav>

<script>
  const items = Array.from(document.querySelectorAll<HTMLAnchorElement>('#appnav .appnav-item'));
  const ids = ['top', 'programs', 'form'];
  const sections = ids.map((id) => document.getElementById(id)).filter(Boolean) as HTMLElement[];

  if (items.length && sections.length) {
    const ratios = new Map<string, number>();
    const setActive = (activeId: string) => {
      items.forEach((i) => i.classList.toggle('is-active', i.getAttribute('data-nav') === activeId));
    };
    const io = new IntersectionObserver(
      (entries) => {
        for (const e of entries) ratios.set(e.target.id, e.isIntersecting ? e.intersectionRatio : 0);
        let activeId = 'top';
        let max = -1;
        for (const [id, r] of ratios) {
          if (r > max) {
            max = r;
            activeId = id;
          }
        }
        setActive(activeId);
      },
      { threshold: [0, 0.25, 0.5, 0.75, 1] },
    );
    sections.forEach((s) => {
      ratios.set(s.id, 0);
      io.observe(s);
    });
  }
</script>
