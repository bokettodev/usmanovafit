---
// Минимальная шапка app-режима: бренд + линия прогресса. Навигация — в нижнем таб-баре.
// CTA «Выбрать программу» появляется после ухода с первого экрана.
---

<header id="siteHeader" data-liquid-ignore class="fixed inset-x-0 top-0 z-40">
  <div class="mx-auto flex h-14 max-w-6xl items-center justify-between px-4 sm:px-6">
    <a href="#top" class="text-base font-extrabold tracking-tight sm:text-lg" aria-label="На главную">
      USMANOVA<span class="text-pink">FIT</span>
    </a>

    <a
      href="#form"
      class="header-cta whitespace-nowrap rounded-full bg-pink px-4 py-2 text-sm font-semibold text-white shadow-sm shadow-pink/30 transition-transform duration-200 hover:-translate-y-0.5 hover:bg-pink-hot active:translate-y-0"
    >
      Выбрать программу
    </a>
  </div>

  <!-- Линия прогресса скролла -->
  <div
    id="scrollProgress"
    aria-hidden="true"
    class="scroll-progress absolute inset-x-0 bottom-0 h-[3px] bg-gradient-to-r from-pink to-pink-hot"
  >
  </div>
</header>
